  "keyFeatures": [
    "Undetectable browser automation using Chrome DevTools Protocol",
    "Async-first Python API for high performance",
    "Smart element lookup with text matching and best match filtering",
    "Automatic cookie and profile management",
    "First-class Docker support with GPU acceleration",
    "Advanced keyboard input system with modifiers and special keys",
    "Request/response interception and monitoring",
    "Cloudflare and anti-bot bypass capabilities",
    "Screenshot, PDF export, and MHTML snapshot support"
  ],
